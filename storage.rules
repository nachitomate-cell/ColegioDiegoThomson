rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /comprobantes/{cuotaId}/{archivo} {
      // Escritura: usuario autenticado, archivo ≤ 5 MB, solo imagen o PDF,
      // y el metadato subidoPor debe coincidir con el UID del usuario.
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType.matches('application/pdf.*'))
                   && request.resource.metadata.subidoPor == request.auth.uid;

      // Lectura: cualquier usuario autenticado puede leer su propio comprobante.
      allow read: if request.auth != null
                  && resource.metadata.subidoPor == request.auth.uid;

      // Borrado solo desde backend (Admin SDK), nunca desde el cliente.
      allow delete: if false;
    }

    // Comprobantes subidos DIRECTAMENTE por secretaría/admin (sin pasar por apoderado).
    // Nota: la condición de apoderado usa estudiante_id == request.auth.uid porque
    // el modelo actual de Auth identifica al apoderado por el UID del estudiante.
    // Actualizar si el modelo de Auth cambia en el futuro.
    match /comprobantes-manuales/{cuotaId}/{archivo} {
      allow write: if request.auth != null
                   && (request.auth.token.role == 'admin'
                       || request.auth.token.role == 'secretaria'
                       || exists(/databases/(default)/documents/Admins/$(request.auth.uid)))
                   && request.resource.size < 5 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType.matches('application/pdf.*'));

      allow read:  if request.auth != null
                   && (
                     // Admin vía colección Admins
                     exists(/databases/(default)/documents/Admins/$(request.auth.uid))
                     // Admin o secretaria vía custom claim
                     || request.auth.token.role == 'admin'
                     || request.auth.token.role == 'secretaria'
                     // Apoderado dueño de la cuota relacionada
                     || (
                       exists(/databases/(default)/documents/Cuotas/$(cuotaId))
                       && get(/databases/(default)/documents/Cuotas/$(cuotaId)).data.estudiante_id == request.auth.uid
                     )
                   );

      allow delete: if false;
    }
  }
}
