rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /comprobantes/{cuotaId}/{archivo} {
      // Escritura: usuario autenticado, archivo ≤ 5 MB, solo imagen o PDF,
      // y el metadato subidoPor debe coincidir con el UID del usuario.
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf')
                   && request.resource.metadata.subidoPor == request.auth.uid;

      // Lectura: cualquier usuario autenticado puede leer su propio comprobante.
      allow read: if request.auth != null
                  && resource.metadata.subidoPor == request.auth.uid;

      // Borrado solo desde backend (Admin SDK), nunca desde el cliente.
      allow delete: if false;
    }
  }
}
