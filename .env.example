# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copia este archivo a .env.local y completa los valores.
# NUNCA subas .env.local al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase (cliente) ────────────────────────────────────────────────────────
# Obtener desde: Firebase Console → Configuración del proyecto → Tus apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin SDK (solo servidor) ───────────────────────────────────────
# Obtener desde: Firebase Console → Configuración del proyecto → Cuentas de servicio
# → Generar nueva clave privada (descarga un JSON)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_PRIVATE_KEY_ID=
# La private_key debe estar entre comillas dobles con \n literales (no saltos reales)
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_CLIENT_ID=

# ── Transbank WebPay Plus ─────────────────────────────────────────────────────
# INTEGRACIÓN (sandbox para pruebas):
#   Commerce Code: 597055555532
#   API Key:       579B532A7440BB0C9079DED94D31EA1615BACEB56610332264630D42D0A36B1
#   Environment:   INTEGRATION
#
# PRODUCCIÓN (cuando Transbank certifique el comercio):
#   Commerce Code: el asignado por Transbank al colegio
#   API Key:       la entregada por Transbank al colegio
#   Environment:   PRODUCTION
TRANSBANK_COMMERCE_CODE=597055555532
TRANSBANK_API_KEY=579B532A7440BB0C9079DED94D31EA1615BACEB56610332264630D42D0A36B1C
TRANSBANK_ENVIRONMENT=INTEGRATION

# ── URL pública de la app ─────────────────────────────────────────────────────
# Desarrollo local:  http://localhost:3000
# Vercel preview:    https://colegio-xxx.vercel.app
# Producción:        https://pagos.colegiodiegothomson.cl  (o el dominio final)
# URL pública (localhost para desarrollo, se sobreescribe en Vercel)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── SMTP (correo de recuperación de contraseña) ──────────────────────────────
# Para Gmail: activa "Contraseñas de aplicación" en tu cuenta Google y usa esa
# contraseña de 16 caracteres en SMTP_PASS (no la clave normal de Gmail).
# Host Gmail:   smtp.gmail.com  | Puerto: 587 | SMTP_SECURE=false
# Host Outlook: smtp.office365.com | Puerto: 587 | SMTP_SECURE=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=correo@colegiodiegothomson.cl
SMTP_PASS=contraseña_de_aplicacion_aqui
# Opcional: nombre del remitente visible (si se omite, usa SMTP_USER)
SMTP_FROM=noreply@colegiodiegothomson.cl

# ── Khipu API v3 ──────────────────────────────────────────────────────────────
# Obtener desde: khipu.com → Mi Perfil → Opciones para desarrolladores → API
# NOTA: KHIPU_RECEIVER_ID fue eliminado en v3. Solo se necesita el API key.
KHIPU_SECRET=
