rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function esAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/Admins/$(request.auth.uid));
    }

    function esElEstudiante(estudianteId) {
      return request.auth != null && request.auth.uid == estudianteId;
    }

    // ── Admins ─────────────────────────────────────────────────────────────────
    match /Admins/{uid} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ── Estudiantes ────────────────────────────────────────────────────────────
    // El doc ID == Firebase Auth UID del estudiante.
    // El estudiante puede leer y actualizar su propio doc (p.ej. quitar requiere_cambio_clave).
    match /Estudiantes/{estudianteId} {
      allow read:   if esElEstudiante(estudianteId) || esAdmin();
      allow create: if esAdmin();
      allow update: if esAdmin() ||
                      (esElEstudiante(estudianteId) &&
                       request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['requiere_cambio_clave']));
      allow delete: if false;
    }

    // ── Cuotas ─────────────────────────────────────────────────────────────────
    // El campo estudiante_id == Firebase Auth UID del estudiante.
    match /Cuotas/{cuotaId} {
      allow read:   if esAdmin() ||
                      (request.auth != null &&
                       resource.data.estudiante_id == request.auth.uid);

      allow update: if esAdmin() ||
                      (request.auth != null &&
                       resource.data.estudiante_id == request.auth.uid &&
                       request.resource.data.estado == 'en_revision' &&
                       request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['estado', 'comprobante_url', 'fecha_envio']));

      allow create: if esAdmin();
      allow delete: if false;
    }

    // ── Apoderados (colección legada, solo admin) ──────────────────────────────
    match /Apoderados/{uid} {
      allow read:   if esAdmin();
      allow write:  if esAdmin();
    }
  }
}
